{
  "rewrites": [
    {
      "source": "/auth-api/:path*",
      "destination": "https://nomikos-auth-service.onrender.com/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://no-mi-kos-back.onrender.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
